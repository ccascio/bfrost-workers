{
    "id": "mastodon-publisher",
    "name": "Mastodon Publisher",
    "tagline": "Posts news.article summaries to a Mastodon instance using the Mastodon API.",
    "description": "A consumer worker that reads `news.article` items from the BFrost Item Bus and posts each one as a toot to a configured Mastodon instance. Supports custom post templates, hashtag injection from article tags, and a 500-character truncation guard with a link appended.\n\nAuthenticate via an access token from your Mastodon instance's developer settings. The token is stored in BFrost's worker settings \u2014 never committed to source.",
    "author": "@ccascio",
    "repoUrl": "https://github.com/ccascio/bfrost-workers",
    "category": "Communication",
    "tags": [
        "mastodon",
        "fediverse",
        "social",
        "publisher",
        "consumer"
    ],
    "trust": "Community",
