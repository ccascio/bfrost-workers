{
  "name": "@bfrost/manifest-schema",
  "version": "1.0.0",
  "description": "Canonical enum types for BFrost worker manifests — single source of truth for TrustLevel, WorkerCategory, and WorkerPermission.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-cjs.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccascio/bfrost-workers.git",
    "directory": "packages/manifest-schema"
  },
  "keywords": ["bfrost", "manifest", "schema", "enums"],
  "license": "MIT"
}
